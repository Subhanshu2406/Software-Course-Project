    {
      "title": "Coordinator TPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(coordinator_committed_total[1m])",
          "legendFormat": "committed/s"
        },
        {
          "expr": "rate(coordinator_aborted_total[1m])",
          "legendFormat": "aborted/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "title": "Coordinator Uptime",
      "type": "stat",
