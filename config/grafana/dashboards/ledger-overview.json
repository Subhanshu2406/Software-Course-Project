      "targets": [
        { "expr": "coordinator_uptime_seconds", "legendFormat": "uptime" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" } },
        "overrides": []
      }
    },
