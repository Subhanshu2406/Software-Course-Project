# ── Cluster topology ──────────────────────────────────────────────
NUM_SHARDS=3
NUM_COORDINATORS=1
FOLLOWERS_PER_SHARD=2
TOTAL_PARTITIONS=30

# ── Load test parameters ──────────────────────────────────────────
NUM_USERS=1000
STARTING_BALANCE=10000
LOAD_VUS=50
LOAD_DURATION=60s

# ── Failure test parameters ───────────────────────────────────────
KILL_DELAY_MS=500
RECOVERY_TIMEOUT_S=30

# ── Migration test parameters ─────────────────────────────────────
HOTSPOT_REQUESTS=600
MIGRATION_TIMEOUT_S=90

# ── Docker Compose profiles (auto-set by Makefile) ────────────────
COMPOSE_PROFILES=three-shards,followers,followers-s2,followers-s3
HOTSPOT_THRESHOLD=5
POLL_INTERVAL=1s
MIGRATION_COOLDOWN=2s
